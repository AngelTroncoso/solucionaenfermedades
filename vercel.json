{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/nitro",
      "config": {
        "preset": "vercel"
      }
    }
  ],
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/.output",
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=8192"
  }
}