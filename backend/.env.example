# ============================================================
# CONFIGURACIÓN DE API — HACKATHON QWEN / ALIBABA CLOUD
# ============================================================

# Proveedor principal (dashscope = Alibaba Cloud, openrouter = fallback)
LLM_PROVIDER=dashscope

# --- DashScope (Alibaba Cloud) — RECOMENDADO PARA HACKATHON ---
# Obtener en: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# --- OpenRouter (fallback) ---
# Obtener en: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# --- Distribución de modelos Qwen (no modificar salvo pruebas) ---
MODEL_REASONING=qwen3-235b-a22b
MODEL_EVALUATION=qwen3-32b
MODEL_REFINER=qwen2.5-72b-instruct
MODEL_LIGHT=qwen2.5-7b-instruct
MODEL_EMBEDDINGS=text-embedding-v3

# --- Parámetros del loop ---
MAX_ITERATIONS=10
FITNESS_THRESHOLD=0.80
POPULATION_SIZE=10
MUTATION_RATE=0.30
EARLY_STOP_ROUNDS=3
<task_progress>
- [x] PASO 1: Auditoría de modelos actuales (completado)
- [x] PASO 2: Actualizar config/settings.py con distribución Qwen (completado)
- [x] PASO 3: Actualizar utils/llm_utils.py (completado)
- [ ] PASO 4: Asignar modelo correcto en cada agente
- [x] PASO 5: Actualizar .env.example (completado)
- [ ] PASO 6: Verificación final
</task_progress>
</write_to_file>