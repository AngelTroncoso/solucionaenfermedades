# API Keys
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Database
DATABASE_URL=sqlite:///./data/drug_database/pharma.db

# External APIs
PUBMED_API_KEY=your_pubmed_api_key_here
CHEMBL_API_KEY=your_chembl_api_key_here

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.7

# Application
LOG_LEVEL=INFO
DEBUG=false

# Dashboard
DASHBOARD_PORT=8501
DASHBOARD_TITLE=Pharma Loop Engineering